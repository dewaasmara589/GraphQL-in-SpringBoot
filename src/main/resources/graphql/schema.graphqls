}

#Object Types (output types)
type Book {
    #Scalars types is Int, Float, String, Boolean, ID, Scalar Extensions
    id: Int!
    title: String!
    author: Author
}

type Author {
    id: ID!
    name: String!
    books: [Book!]!
}

input BookInput{
    title: String!
    authorId: Int!
}

union SearchItem = Author | Book